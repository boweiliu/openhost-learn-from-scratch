:{$APP_PORT:8080} {
	encode gzip

	handle /health {
		respond "ok" 200
	}

	@root path /
	redir @root /app/

	redir /terminal /terminal/

	handle /terminal/* {
		reverse_proxy 127.0.0.1:{$TTYD_PORT:7681}
	}

	@app path /app /app/*
	handle @app {
		reverse_proxy 127.0.0.1:{$VITE_PORT:5173}
	}

	handle {
		reverse_proxy 127.0.0.1:{$VITE_PORT:5173}
	}
}
