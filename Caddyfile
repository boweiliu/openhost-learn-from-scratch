:{$APP_PORT:8080} {
	encode gzip

	handle /health {
		respond "ok" 200
	}

	@root path /
	redir @root /app/

	redir /terminal /terminal/

	handle /terminal/* {
		reverse_proxy 127.0.0.1:{$TTYD_PORT:7681}
	}

	@appRoot path /app
	handle @appRoot {
		rewrite * /
		reverse_proxy 127.0.0.1:{$VITE_PORT:5173}
	}

	handle_path /app/* {
		reverse_proxy 127.0.0.1:{$VITE_PORT:5173}
	}

	handle {
		reverse_proxy 127.0.0.1:{$VITE_PORT:5173}
	}
}
